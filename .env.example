# ── OCODX Environment Configuration ───────────────────────────────────────────

# ── AI Provider Configuration ─────────────────────────────────────────────────
# Options: ollama | ollama_cloud | lmstudio | gemini | huggingface
AI_PROVIDER=ollama

# ── Ollama (Local) ────────────────────────────────────────────────────────────
# Host for local Ollama daemon. Use http://host.docker.internal:11434 for Docker.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_API_KEY=

# ── Ollama Cloud ──────────────────────────────────────────────────────────────
# Get key from https://ollama.com/settings/keys
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL=gpt-oss:120b

# ── LM Studio ─────────────────────────────────────────────────────────────────
# Host for local LM Studio. Use http://host.docker.internal:1234 for Docker.
LMSTUDIO_HOST=http://localhost:1234
LMSTUDIO_MODEL=local-model

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get key from https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── HuggingFace ───────────────────────────────────────────────────────────────
HUGGINGFACE_API_TOKEN=

# ── Joomla MCP (Optional) ─────────────────────────────────────────────────────
JOOMLA_BASE_URL=
JOOMLA_BEARER_TOKEN=

# ── YOO Builder MySQL (Optional) ──────────────────────────────────────────────
# Enables direct DB layout surgery bypassing REST
YOOMYSQL_HOST=
YOOMYSQL_PORT=3306
YOOMYSQL_USER=
YOOMYSQL_PASSWORD=
YOOMYSQL_DATABASE=
YOOMYSQL_PREFIX=jos_

# ── Playwright (AionUI) ───────────────────────────────────────────────────────
# Set to 'headless' for Docker, or empty for headed (requires X11/VNC)
PLAYWRIGHT_HEADLESS=true
